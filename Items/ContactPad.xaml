<ListBoxItem
    x:Class="VoiceX.Items.ContactPad"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:my="using:Microsoft.Toolkit.Uwp.UI"
    xmlns:local="using:VoiceX.Items"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Padding="0,0,0,0" BorderBrush="#FFF2F3F4">
    <Grid Background="#FFFDFEFF"  BorderThickness="0, 0, 0, 1">
        <TextBlock x:Name="userName" Text="Amelia Rogers" FontSize="14" FontFamily="Nunito Sans 10pt Normal" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,3,0,0"/>
        <TextBlock x:Name="userPhone" Text="050 245 4884" FontSize="12" FontFamily="Nunito Sans 10pt Normal" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,23,0,3" Foreground="#FF959595"/>
        <CheckBox PointerEntered="Cursor_PointerEntered" PointerExited="Cursor_PointerExited" x:Name="Select" Click="Select_Click" MinWidth="10" FontFamily="/Assets/Fonts/Inter-Regular.ttf#Inter" MinHeight="10" Style="{StaticResource CheckBoxStyle}" VerticalAlignment="Top" Foreground="#FF5C66BD" FontSize="6" HorizontalAlignment="Right" Background="Transparent" Margin="0,11,0,0" Height="20"/>
        <Button PointerEntered="Cursor_PointerEntered" PointerExited="Cursor_PointerExited" x:Name="Transfer" Click="Transfer_Click" Background="Transparent" Style="{StaticResource ButtonStyleMenu}" HorizontalAlignment="Right" VerticalAlignment="Top" BorderBrush="{x:Null}" Width="16" Height="16" Margin="0,13,2.2,0" Padding="0,0,0,0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Button.Content>
                <Grid Margin="0,0,-1,-1" Width="11" Height="12">
                    <Grid Height="1.5" Width="10" CornerRadius="1" VerticalAlignment="Top" Background="#FF261EF3" HorizontalAlignment="Right"/>
                    <Grid Width="1.5" Height="10" CornerRadius="1" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#FF261EF3"/>
                    <Grid Height="1.5" Width="12" CornerRadius="1" RenderTransformOrigin="0.5,0.5" Background="#FF261EF3" Margin="0,4,-1,6" UseLayoutRounding="False" d:LayoutRounding="Auto">
                        <Grid.RenderTransform>
                            <CompositeTransform Rotation="-45"/>
                        </Grid.RenderTransform>
                    </Grid>
                </Grid>
            </Button.Content>
        </Button>
    </Grid>
</ListBoxItem>
