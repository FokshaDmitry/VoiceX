<ListBoxItem
    x:Class="VoiceX.Items.HistoryNote"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Padding="0,0,0,0" BorderThickness="0" Background="White" Loaded="HistoryNote_Loaded" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
    <ListBoxItem.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand" Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ListBoxItem.Resources>
    <Border Background="#FFFDFEFF" Padding="6,3,0,1">
        <Grid x:Name="ContactVisability">
            <Grid Width="30" HorizontalAlignment="Left" Height="30" VerticalAlignment="Top" Margin="0,3,0,0" >
                <Image Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Fill"/>
                <Border x:Name="contactBackgroundColor" Background="#FFE5A7E0" CornerRadius="50" >
                    <TextBlock RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" Text="N" x:Name="FirstWord" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Inter" Foreground="#FFFDFEFF"/>
                </Border>
            </Grid>
            <TextBlock RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" ToolTip="Copy Number" Cursor="Hand" MouseDown="UserName_MouseDown" TextTrimming="CharacterEllipsis" FontFamily="Nunito Sans 10pt Normal" Text="Name" x:Name="UserName" HorizontalAlignment="Left" Margin="40,5,0,0"  TextWrapping="NoWrap"  VerticalAlignment="Top" FontWeight="Normal" FontSize="12" Foreground="Black"/>
            <TextBlock RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" FontFamily="Nunito Sans 10pt Normal" Text="Time" x:Name="Time" HorizontalAlignment="Left" Margin="54,22,0,0" TextWrapping="NoWrap"  VerticalAlignment="Top" FontWeight="Normal" FontSize="10" Foreground="#FF727070"/>
            <Grid Height="12" Width="12" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,22,0,0">
                <Grid x:Name="IncomeCall" Visibility="Collapsed">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Height="1" Width="6.5" CornerRadius="0.5" Background="#FF261EF3" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
                        <Border Height="6.5" Width="1" CornerRadius="0.5" Background="#FF261EF3" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Border Height="7" Width="1" CornerRadius="0.5" Background="#FF261EF3" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="0,0,0.8,-1.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="50"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Border.RenderTransform>

                        </Border>
                    </Grid>
                </Grid>
                <Grid Visibility="Collapsed" x:Name="OutcomeCall">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Height="1" Width="6.5" CornerRadius="0.5" Background="#FF06D665" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <Border Height="6.5" Width="1" CornerRadius="0.5" Background="#FF06D665" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Border Height="7" Width="1" CornerRadius="0.5" Background="#FF06D665" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="0.8,-1.5,0,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="50"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Border.RenderTransform>

                        </Border>
                    </Grid>
                </Grid>
                <Grid Visibility="Collapsed" x:Name="MissedCall">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Height="1" Width="6.5" CornerRadius="0.5" Background="#FFF31E38" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <Border Height="6.5" Width="1" CornerRadius="0.5" Background="#FFF31E38" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Border Height="7" Width="1" CornerRadius="0.5" Background="#FFF31E38" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="0.8,-1.5,0,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="50.501"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Border.RenderTransform>

                        </Border>
                        <Border Height="4.5" Width="1" CornerRadius="0.5" Background="#FFF31E38" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="-7,0.5,0,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-56.479"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Border.RenderTransform>

                        </Border>
                    </Grid>
                </Grid>
                <Grid Visibility="Collapsed" x:Name="MissedInCall" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="-180"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Height="1" Width="6.5" CornerRadius="0.5" Background="#FFF31E38" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="2.8,0,0,0"/>
                        <Border Height="6.5" Width="1" CornerRadius="0.5" Background="#FFF31E38" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,3.5"/>
                        <Border Height="7" Width="1" CornerRadius="0.5" Background="#FFF31E38" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="3.1,-4.2,0,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="50.501"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Border.RenderTransform>

                        </Border>
                        <Border Height="4.5" Width="1" CornerRadius="0.5" Background="#FFF31E38" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="2,3,3.6,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="1.339"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Border.RenderTransform>

                        </Border>
                    </Grid>
                </Grid>
            </Grid>
            <Button BorderThickness="0" Cursor="Hand" Height="18" Width="18" HorizontalAlignment="Right" Margin="0,6,15,0" VerticalAlignment="Top" Padding="0,0,0,0">
                <Button.Content>
                    <Border Height="18" Width="18">
                        <Border.Background>
                            <ImageBrush>
                                <ImageBrush.ImageSource>
                                    <BitmapImage UriSource="/Assets/Icone_v2/ContactMessage.png" DecodePixelWidth="70" DecodePixelHeight="70"/>
                                </ImageBrush.ImageSource>
                            </ImageBrush>
                        </Border.Background>
                    </Border>
                </Button.Content>
            </Button>
            <Button BorderThickness="0" x:Name="Call" Click="Call_Click" Cursor="Hand" Height="20" Width="20" HorizontalAlignment="Right" Margin="0,6,40,0" VerticalAlignment="Top" Padding="0,0,0,0">
                <Button.Content>
                    <Border Height="18" Width="18">
                        <Border.Background>
                            <ImageBrush>
                                <ImageBrush.ImageSource>
                                    <BitmapImage UriSource="/Assets/Icone_v2/ContactPhone.png" DecodePixelWidth="70" DecodePixelHeight="70"/>
                                </ImageBrush.ImageSource>
                            </ImageBrush>
                        </Border.Background>
                    </Border>
                </Button.Content>
            </Button>
        </Grid>
    </Border>
</ListBoxItem>
