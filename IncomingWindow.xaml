<Window x:Class="VoiceX.IncomingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoiceX"
        mc:Ignorable="d"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        Topmost="True"
        Title="IncomingWindow" Background="Transparent" Padding="0, 0, 0, 0" Height="261" Width="242">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand" Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderThickness="0" CornerRadius="24" 
            Background="White"
            BorderBrush="#FFEEEEEE">
        <Grid>
            <TextBlock Text="Incoming call" HorizontalAlignment="Center" Margin="0,16,0,0" VerticalAlignment="Top" Foreground="#FF06D665" FontSize="16"/>
            <Grid Width="115" Height="115" VerticalAlignment="Top" Margin="0,37,0,0">
                <Ellipse StrokeThickness="0" Width="115" Height="115" Fill="GhostWhite"/>
                <Ellipse StrokeThickness="0" Width="93.4" Height="93.4" Fill="#FFE8E3FD"/>
                <Ellipse StrokeThickness="0" Width="77.5" Height="77.5" Fill="#FF9599FD"/>
                <Image Width="58.5" Height="58.5">
                    <Image.Source>
                        <BitmapImage UriSource="/Assets/Icone_v2/Avatar.png" DecodePixelWidth="500" DecodePixelHeight="500"/>
                    </Image.Source>
                </Image>
            </Grid>
            <TextBlock x:Name="UserName" FontFamily="Nunito Sans 10pt Normal" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,158,0,0" />
            <TextBlock x:Name="UserPhone" FontFamily="Nunito Sans 10pt Normal" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,179,0,0" />
            <Grid VerticalAlignment="Top" Margin="0,213,0,0" Height="49">
                <Button Name="Accept" Click="Accept_Click" Cursor="Hand" Padding="0, 0, 0, 0" Height="48" Width="121" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" >
                    <Button.Content>
                        <Border CornerRadius="0, 0, 0, 24" Height="48" Width="121" Background="#FFE7FFE5">
                            <Image Width="24" Height="24">
                                <Image.Source>
                                    <BitmapImage UriSource="/Assets/Icone_v2/Icon-Phone.png" DecodePixelWidth="500" DecodePixelHeight="500"/>
                                </Image.Source>
                            </Image>
                        </Border>
                    </Button.Content>
                </Button>
                <Button Name="Ignore" Click="Ignore_Click" Cursor="Hand" Padding="0, 0, 0, 0" Height="48" Width="121" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Margin="121,0,0,0" >
                    <Button.Content>
                        <Border CornerRadius="0, 0, 24, 0" Height="48" Width="121" Background="#FFFFE9E5">
                            <Image Width="24" Height="24">
                                <Image.Source>
                                    <BitmapImage UriSource="/Assets/Icone_v2/Icon-PhoneSlash.png" DecodePixelWidth="500" DecodePixelHeight="500"/>
                                </Image.Source>
                            </Image>
                        </Border>
                    </Button.Content>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
