<Page
    x:Class="VoiceX.Items.MoreItems"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceX.Items"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Button Style="{StaticResource ButtonStyleMenu}" PointerEntered="More_PointerEntered" PointerExited="More_PointerExited" Background="Transparent" x:Name="More" Click="More_Click" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Button.Content>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TextColor" Text="Show more" Foreground="#FF8761F6" FontFamily="Nunito Sans 10pt Normal" FontSize="14"/>
                    <Polyline x:Name="AngleColor" Stroke="#FF8761F6" Points="0, 5, 5, 0, 10, 5" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="3,2,0,0" >
                        <Polyline.RenderTransform>
                            <CompositeTransform Rotation="180"/>
                        </Polyline.RenderTransform>
                    </Polyline>
                </StackPanel>
            </Button.Content>
        </Button>
    </Grid>
</Page>
