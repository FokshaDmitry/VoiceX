<Page
    x:Class="VoiceX.Views.ClientPages.ContactsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceX.Views.ClientPages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2,0,0" BorderThickness="0, 0, 0, 1" BorderBrush="#FFDADADB">
            <TextBox BorderThickness="0" KeyDown="Search_KeyDown" PointerEntered="Cursor_PointerEntered" PointerExited="Cursor_PointerExited" Style="{StaticResource TextBoxStyle}" PlaceholderText="Contacts" PointerPressed="ContactsPage_PointerPressed" x:Name="Search"  MinHeight="26" TextChanging="SearchFild_TextChanging" Width="225" BorderBrush="{x:Null}" SelectionHighlightColor="#FFA7B7F5" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="14" Height="25" Padding="6,0,6,0"/>
            <Button PointerEntered="Cursor_PointerEntered" PointerExited="Cursor_PointerExited" Click="magnifyingGlass_Click" Background="Transparent" Style="{StaticResource ButtonStyleMenu}" Padding="0" Height="20" x:Name="magnifyingGlass" Width="20" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,3">
                <Button.Content>
                    <Grid>
                        <Grid x:Name="magnifyingGlassLine" Background="#FF898989" Height="1.1" Width="6" CornerRadius="1" RenderTransformOrigin="0.5,0.5" Margin="8,8.6,0,0">
                            <Grid.RenderTransform>
                                <CompositeTransform Rotation="44.45"/>
                            </Grid.RenderTransform>
                        </Grid>
                        <Ellipse x:Name="magnifyingGlassEllipse" Fill="White" StrokeThickness="1" Width="10" Height="11" Stroke="#FF898989"/>
                    </Grid>
                </Button.Content>
            </Button>
        </Grid>

        <ListBox Style="{StaticResource ListBoxStyle}" PointerPressed="ContactsPage_PointerPressed" x:Name="ContactsList" MaxWidth="500" Margin="10,30,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White" Padding="0,0,10,0"/>

    </Grid>
</Page>
