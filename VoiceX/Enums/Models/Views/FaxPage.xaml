                </Button>
                <Button Name="Phone" PointerEntered="Navigate_PointerEntered" PointerExited="Navigate_PointerExited" Margin="70,10,0,0" Click="Navigate_Click" Style="{StaticResource ButtonStyle}" Width="18" BorderBrush="{x:Null}" Padding="0,0,0,0" Height="18" VerticalAlignment="Top">
                    <Button.Background>
                        <ImageBrush ImageSource="/Assets/Icone_v2/phoneNavigate.png"/>
                    </Button.Background>
