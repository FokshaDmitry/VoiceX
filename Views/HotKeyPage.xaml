<Page
    x:Class="VoiceX.Views.HotKeyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceX.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="White">
    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand" >
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid x:Name="HotKeyMainGrid" Width="245">
        <Grid Margin="0,45,0,0">
            <Grid x:Name="PageContent">
                <Border BorderThickness="0, 0, 0, 1" BorderBrush="#FFC1BFFF" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2,0,0">
                    <Grid>
                        <TextBox BorderThickness="0" x:Name="Search"  MinHeight="26" TextChanged="Search_TextChanged" Width="225" BorderBrush="#FF8F8F8F" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="14" Height="25" Padding="6,0,6,0"/>
                        <Grid Height="15" x:Name="magnifyingGlass" Width="15" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,3">
                            <Border x:Name="magnifyingGlassLine" Background="#FFC1BFFF" Height="1.1" Width="6" CornerRadius="1" RenderTransformOrigin="0.5,0.5" Margin="8,8.6,0,0">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="45"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Border.RenderTransform>

                            </Border>
                            <Ellipse x:Name="magnifyingGlassEllipse" Fill="White" StrokeThickness="1" Width="10" Height="11" Stroke="#FFC1BFFF"/>
                        </Grid>
                    </Grid>
                </Border>
                <ListBox BorderThickness="0" x:Name="ContactsList" MaxWidth="500" Margin="10,30,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White" Padding="0,0,10,0"/>
                <Button Name="AddHotkeyButton" Click="AddHotkeyButton_Click" Padding="0"  Height="38" Width="38" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,20,70" >
                    <Button.Content>
                        <Border  Background="#FFE6E5FF" CornerRadius="50">
                            <Grid>
                                <Border Height="21" Width="2" CornerRadius="1.3" Background="#FF7B76FF" />
                                <Border Height="2" Width="21" CornerRadius="1.3" Background="#FF7B76FF" />
                            </Grid>
                        </Border>
                    </Button.Content>
                </Button>
            </Grid>
        </Grid>
        <Grid x:Name="AddHotkeyFild" Visibility="Collapsed" Background="#CC202244">
            <Border CornerRadius="12" Background="White" Width="204" Height="200">
                <Grid>
                    <Button Click="Button_Click" Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,5,6,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                        <Button.Content>
                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Border CornerRadius="0.5" Width="9.4" Height="1" Background="#FF252422" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="45"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Border.RenderTransform>

                                </Border>
                                <Border CornerRadius="0.5" Width="9.4" Height="1" Background="#FF252422" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="-45"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Border.RenderTransform>

                                </Border>
                            </Grid>
                        </Button.Content>
                    </Button>
                    <TextBlock Text="Add Hotkey" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,18,0,0" FontSize="20" FontFamily="Nunito Sans 10pt Normal"/>
                    <Button Name="SaveHotkey" Click="SaveHotkey_Click" VerticalAlignment="Bottom" Margin="0,0,10,15" Width="148" Height="32" FontSize="18" FontFamily="Jost" Foreground="#E4FFFFFF" Padding="0,0,0,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold">
                        <Button.Content>
                            <Border CornerRadius="17" Background="#FF8A63FB">
                                <TextBlock Text="Save" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Button.Content>
                    </Button>
                    <TextBox x:Name="UserName" BorderThickness="1" Width="172" Height="32" BorderBrush="#FFBBBAFF" VerticalAlignment="Top" Margin="0,54,0,0" FontFamily="Nunito Sans 10pt Normal" Padding="10,6.5,6,6"/>
                    <TextBox x:Name="UserPhone" BorderThickness="1" Width="172" Height="32" BorderBrush="#FFBBBAFF" VerticalAlignment="Top" Margin="0,102,0,0" FontFamily="Nunito Sans 10pt Normal" Padding="10,6.5,6,6"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
