<Page
    x:Class="VoiceX.Views.PhonePages.DialpadCallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceX.Views.PhonePages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FFFDFEFF" Margin="0, 50, 0, 0" GotFocus="Page_GotFocus" Loaded="Page_Loaded">
    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border  CornerRadius="50" Background="#FFF4F4FF">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>
        <Border BorderThickness="0,0,0,1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,10,0" BorderBrush="#FFDEDEFF">
            <Grid>
                <TextBox PreviewTextInput="NumberFild_PreviewTextInput" PreviewKeyDown="NumberFild_PreviewKeyDown" CaretBrush="Transparent" Cursor="Hand" TextChanged="NumberFild_TextChanged" KeyDown="NumberFild_KeyDown" TextAlignment="Center" BorderThickness="0"  MinHeight="10"  x:Name="NumberFild" FontFamily="Nunito Sans 10pt Normal" Canvas.Left="2" BorderBrush="#FFC2C3C3" FontSize="14" Height="23" VerticalAlignment="Top" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Width="189" Padding="0,0,0,0" Background="#FFFDFEFF"/>
                <Button PreviewMouseLeftButtonUp="Backspace_PreviewMouseLeftButtonUp" PreviewMouseLeftButtonDown="Backspace_PreviewMouseRightButtonDown" Cursor="Hand" BorderBrush="Transparent" BorderThickness="0" Visibility="Collapsed" Click="Backspace_Click" Height="15" Background="Transparent" Padding="-2,-2,-2,-2" Width="15" x:Name="Backspace" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,2" >
                    <Button.Content>
                        <Image Height="15" Width="15" Stretch="Fill">
                            <Image.Source>
                                <BitmapImage UriSource="/Assets/Icone_v2/Backspace.png" DecodePixelWidth="60" DecodePixelHeight="60"/>
                            </Image.Source>
                        </Image>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>
        <Grid Margin="0,34,0,0" Width="189">
            <Button  Cursor="Hand" Click="Button1_Click" Content="1" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" Padding="0,0,0,0" UseLayoutRounding="False"  Grid.RowSpan="2" HorizontalAlignment="Left"/>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="2" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" HorizontalAlignment="Center" Grid.RowSpan="2"/>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="3" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" HorizontalAlignment="Right" Grid.RowSpan="2"/>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="4" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,52,0,0" Grid.Row="1" HorizontalAlignment="Left"/>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="5" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,52,0,0" HorizontalAlignment="Center" Grid.Row="1"/>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="6" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,52,0,0" HorizontalAlignment="Right" Grid.Row="1"/>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="7" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,104,0,0" Grid.Row="1" HorizontalAlignment="Left"/>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="8" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,104,0,0" HorizontalAlignment="Center" Grid.Row="1"/>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="9" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="26" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,104,0,0" HorizontalAlignment="Right" Grid.Row="1"/>
            <Button BorderThickness="0" Content="*" Cursor="Hand" Click="Button1_Click"  VerticalAlignment="Top" Width="44" Height="44" Background="Transparent" FontSize="44" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,5,0,0" UseLayoutRounding="False" Margin="0,156,0,0" Grid.Row="1" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalAlignment="Left">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border  CornerRadius="50" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Button BorderThickness="0" Cursor="Hand" Click="Button1_Click" Content="0" VerticalAlignment="Top" Width="44" Height="44" Background="#FFF4F4FF" FontSize="28" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,156,0,0" HorizontalAlignment="Center" Grid.Row="1"/>
            <Button BorderThickness="0" Content="#" Cursor="Hand" Click="Button1_Click"  VerticalAlignment="Top" Width="44" Height="44" Background="Transparent" FontSize="24" FontFamily="Calibri Light" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,156,0,0" HorizontalAlignment="Right" Grid.Row="1">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border  CornerRadius="50" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Button BorderThickness="0" Cursor="Hand" Click="CallButton_Click" VerticalAlignment="Top" Width="44" Height="44" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,215,0,0" HorizontalAlignment="Center" Grid.Row="1">
                <Button.Content>
                    <Border CornerRadius="50" Background="#FF06D665" Width="42" Height="42">
                        <Image Width="26" Height="26">
                            <Image.Source>
                                <BitmapImage UriSource="/Assets/Icone_v2/Dialpad.png" DecodePixelWidth="90" DecodePixelHeight="90"/>
                            </Image.Source>
                        </Image>
                    </Border>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</Page>
