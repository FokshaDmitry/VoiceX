<Window x:Class="VoiceX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoiceX.Views"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        Closing="Window_Closing"
        Title="VoiceX" MinWidth="260" MouseEnter="Window_MouseEnter" MouseLeave="Window_MouseLeave" Icon="/Assets/Icone_v2/BlueIcon.ico" MinHeight="460" MaxHeight="460" MaxWidth="260" Background="#FFEBE2FF" Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand" Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border CornerRadius="6" Padding="4" Background="White"
            BorderThickness="1"
             BorderBrush="#FFC1BFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Storyboard x:Key="RotationAnimation">
            <!-- Анимация для 1 круга -->
            <DoubleAnimation Storyboard.TargetName="Rotate1"
                                 Storyboard.TargetProperty="Angle"
                                 From="0" To="360"
                                 Duration="0:0:3"
                                 RepeatBehavior="Forever"/>

            <!-- Анимация для 2 круга -->
            <DoubleAnimation Storyboard.TargetName="Rotate2"
                                 Storyboard.TargetProperty="Angle"
                                 From="0" To="360"
                                 Duration="0:0:5"
                                 RepeatBehavior="Forever"/>

            <!-- Анимация для 3 круга -->
            <DoubleAnimation Storyboard.TargetName="Rotate3"
                                 Storyboard.TargetProperty="Angle"
                                 From="0" To="360"
                                 Duration="0:0:2"
                                 RepeatBehavior="Forever"/>

            <!-- Анимация для 4 круга -->
            <DoubleAnimation Storyboard.TargetName="Rotate4"
                                 Storyboard.TargetProperty="Angle"
                                 From="0" To="360"
                                 Duration="0:0:1"
                                 RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource RotationAnimation}"/>
        </EventTrigger>
    </Window.Triggers>
    <Page>

        <Grid>
            <tb:TaskbarIcon x:Name="TrayIcon"
            IconSource="/Assets/icone_v2/TrayIcon.ico"
            ToolTipText="VoiceX" TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu Background="Transparent" BorderThickness="0">
                        <ContextMenu.Resources>
                            <Style TargetType="ContextMenu">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Padding="18" Width="167" Height="222" Background="White" BorderBrush="#FFE1DDFF" BorderThickness="1" CornerRadius="24">
                                                <!-- Закругление -->
                                                <StackPanel>
                                                    <ItemsPresenter/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style TargetType="MenuItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">
                                            <Border Padding="0" Margin="0" Background="Transparent" BorderThickness="0, 0, 0, 1" BorderBrush="#FFE3DEFF">
                                                <Grid>
                                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin ="0, 8, 0, 8"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ContextMenu.Resources>
                        <MenuItem BorderThickness="0, 0, 0, 1" BorderBrush="Black" Padding="0" Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" Header="Open" Click="ShowWindow" FontSize="18"/>
                        <MenuItem BorderThickness="0, 0, 0, 1" BorderBrush="Black" Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" FontSize="18" Name="Dialpad" Header="Dialpad" Click="Dialpad_Click"/>
                        <MenuItem BorderThickness="0, 0, 0, 1" BorderBrush="Black" Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" FontSize="18" Name="Clients" Header="Clients" Click="Clients_Click"/>
                        <MenuItem BorderThickness="0, 0, 0, 1" BorderBrush="Black" Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" FontSize="18" Name="Help" Header="Help" Click="Help_Click"/>
                        <MenuItem BorderThickness="0" BorderBrush="Black" Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" FontSize="18" Header="Exit" Click="ExitApplication"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
            <Frame NavigationUIVisibility="Hidden" x:Name="MainPage">
                
            </Frame>
            <Grid Visibility="Collapsed" x:Name="ErrorPlate"  Background="#999692ED" Margin="-5,0,-5,0" >
                <Border CornerRadius="12" Background="White" Width="204" Height="150">
                    <Grid>
                        <Button Cursor="Hand" Click="Close_Click" Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,5,8,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                            <Button.Content>
                                <Border Background="White" Width="16" Height="16">
                                    <Grid Background="White" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <Rectangle RadiusX="0.5" RadiusY="0.5" Width="10.4" Height="1" Fill="#FF252422" RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform/>
                                                    <SkewTransform/>
                                                    <RotateTransform Angle="45"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </Rectangle.RenderTransform>

                                        </Rectangle>
                                        <Rectangle RadiusX="0.5" RadiusY="0.5" Width="10.4" Height="1" Fill="#FF252422" RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform/>
                                                    <SkewTransform/>
                                                    <RotateTransform Angle="-45"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                    </Grid>
                                </Border>
                            </Button.Content>
                        </Button>
                        <Button Cursor="Hand" x:Name="Copy" Click="Copy_Click"  Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,5,29,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                            <Button.Content>
                                <Image Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Top" Width="14" Height="15">
                                    <Image.Source>
                                        <BitmapImage UriSource="/Assets/Icone_v2/copy.png" DecodePixelWidth="500" DecodePixelHeight="500"/>
                                    </Image.Source>
                                </Image>
                            </Button.Content>
                        </Button>
                        <Image Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Top" Width="54" Margin="0,18,0,0">
                            <Image.Source>
                                <BitmapImage UriSource="/Assets/Icone_v2/Error.png" DecodePixelWidth="1000" DecodePixelHeight="1000"/>
                            </Image.Source>
                        </Image>
                        <TextBox BorderThickness="0" FontSize="20" FontFamily="Nunito Sans 10pt Normal" Text="Attention" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,80,0,0"/>
                        <TextBox TextWrapping="Wrap" BorderThickness="0" x:Name="ErrorMessage" Width="143" Height="30" FontSize="14" FontFamily="Nunito Sans 10pt Normal" Text="Attention" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,106,0,0" HorizontalContentAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
            <Grid x:Name="PreAsk" Visibility="Collapsed"  Background="#999692ED" Margin="-5,0,-5,0" >
                <Border CornerRadius="12" Background="White" Width="204" Height="246">
                    <Grid>
                        <Image Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Top" Width="90" Margin="0,18,0,0">
                            <Image.Source>
                                <BitmapImage UriSource="/Assets/Icone_v2/Warning.png" DecodePixelWidth="1000" DecodePixelHeight="1000"/>
                            </Image.Source>
                        </Image>
                        <TextBox BorderThickness="0" FontSize="20" FontFamily="Nunito Sans 10pt Normal" Text="Are you sure?" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,88,0,0"/>
                        <TextBox TextWrapping="Wrap" BorderThickness="0" Width="143" Height="30" FontSize="14" FontFamily="Nunito Sans 10pt Normal" Text="You will not be able to undo this action!" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,114,0,0" HorizontalContentAlignment="Center"/>
                        <Button Cursor="Hand" Click="Continue_Click" VerticalAlignment="Top" Width="143" Height="28" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Margin="0,158,0,0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                            <Button.Content>
                                <Border Padding="0" BorderThickness="0" CornerRadius="15" Background="#FF8861F7">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="Continue" FontSize="18" Foreground="#FFF3F3F3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                    </Grid>
                                </Border>
                            </Button.Content>
                        </Button>
                        <Button Cursor="Hand" Click="Close_Click" VerticalAlignment="Top" Width="143" Height="28" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Margin="0,198,0,0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                            <Button.Content>
                                <Border Padding="0" BorderThickness="1" CornerRadius="15" Background="#FFFDFEFF" BorderBrush="#FF8560F2">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="Cansel" FontSize="18" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                    </Grid>
                                </Border>
                            </Button.Content>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
            <Grid Visibility="Collapsed" x:Name="LoadIcone"  Background="#999692ED">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="88" Height="88">
                    <Ellipse Width="84" Height="84" Fill="Transparent" StrokeThickness="4">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <LinearGradientBrush.GradientStops>
                                    <GradientStop Color="#7B76FF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="0.6526"/>
                                </LinearGradientBrush.GradientStops>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="Rotate1" Angle="-75" CenterX="42" CenterY="42"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Второй круг -->
                    <Ellipse Width="58" Height="58" StrokeThickness="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <LinearGradientBrush.GradientStops>
                                    <GradientStop Color="#BCBAFF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="0.6526" />
                                </LinearGradientBrush.GradientStops>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="Rotate2" Angle="-45" CenterX="29" CenterY="29"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Третий круг -->
                    <Ellipse Width="38" Height="38" StrokeThickness="4">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <LinearGradientBrush.GradientStops>
                                    <GradientStop Color="#D1D0FF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="0.6526"/>
                                </LinearGradientBrush.GradientStops>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="Rotate3" Angle="60" CenterX="19" CenterY="19"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Четвертый круг -->
                    <Ellipse Width="20" Height="20" StrokeThickness="4">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <LinearGradientBrush.GradientStops>
                                    <GradientStop Color="#8833FF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="0.6526"/>
                                </LinearGradientBrush.GradientStops>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.RenderTransform>
                            <RotateTransform  x:Name="Rotate4" Angle="-135" CenterX="10" CenterY="10"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
            </Grid>
        </Grid>
        
    </Page>
    
</Window>
