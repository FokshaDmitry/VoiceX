<Window x:Class="VoiceX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoiceX.Views"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        Closing="Window_Closing"
        Title="VoiceX" MinWidth="260" Icon="/Assets/Icone_v2/icon16.ico" MinHeight="460" MaxHeight="460" MaxWidth="260" Background="#FFEBE2FF" Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand" Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Page>

        <Grid>
            <tb:TaskbarIcon x:Name="TrayIcon"
            IconSource="/Assets/icone_v2/icon24.ico"
            ToolTipText="VoiceX" TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open" Click="ShowWindow"/>
                        <MenuItem Name="Dialpad" Header="Dialpad" Click="Dialpad_Click"/>
                        <MenuItem Name="Clients" Header="Clients" Click="Clients_Click"/>
                        <MenuItem Header="Exit" Click="ExitApplication"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
            <Frame NavigationUIVisibility="Hidden" x:Name="MainPage">
                
            </Frame>
            <Grid Visibility="Collapsed" x:Name="ErrorPlate" Background="#CC202244" Margin="-5,0,-5,0" >
                <Border CornerRadius="12" Background="White" Width="204" Height="150">
                    <Grid>
                        <Button Cursor="Hand" Click="Close_Click" Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,5,8,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                            <Button.Content>
                                <Border Background="White" Width="16" Height="16">
                                    <Grid Background="White" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <Rectangle RadiusX="0.5" RadiusY="0.5" Width="10.4" Height="1" Fill="#FF252422" RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform/>
                                                    <SkewTransform/>
                                                    <RotateTransform Angle="45"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </Rectangle.RenderTransform>

                                        </Rectangle>
                                        <Rectangle RadiusX="0.5" RadiusY="0.5" Width="10.4" Height="1" Fill="#FF252422" RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform/>
                                                    <SkewTransform/>
                                                    <RotateTransform Angle="-45"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                    </Grid>
                                </Border>
                            </Button.Content>
                        </Button>
                        <Button Cursor="Hand" x:Name="Copy" Click="Copy_Click"  Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,5,29,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                            <Button.Content>
                                <Image Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Top" Width="14" Height="15">
                                    <Image.Source>
                                        <BitmapImage UriSource="/Assets/Icone_v2/copy.png" DecodePixelWidth="500" DecodePixelHeight="500"/>
                                    </Image.Source>
                                </Image>
                            </Button.Content>
                        </Button>
                        <Image Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Top" Width="54" Margin="0,18,0,0">
                            <Image.Source>
                                <BitmapImage UriSource="/Assets/Icone_v2/Error.png" DecodePixelWidth="1000" DecodePixelHeight="1000"/>
                            </Image.Source>
                        </Image>
                        <TextBox BorderThickness="0" FontSize="20" FontFamily="Nunito Sans 10pt Normal" Text="Attention" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,80,0,0"/>
                        <TextBox TextWrapping="Wrap" BorderThickness="0" x:Name="ErrorMessage" Width="143" Height="30" FontSize="14" FontFamily="Nunito Sans 10pt Normal" Text="Attention" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,106,0,0" HorizontalContentAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
            <Grid x:Name="PreAsk" Visibility="Collapsed" Background="#CC202244" Margin="-5,0,-5,0" >
                <Border CornerRadius="12" Background="White" Width="204" Height="246">
                    <Grid>
                        <Image Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Top" Width="90" Margin="0,18,0,0">
                            <Image.Source>
                                <BitmapImage UriSource="/Assets/Icone_v2/Warning.png" DecodePixelWidth="1000" DecodePixelHeight="1000"/>
                            </Image.Source>
                        </Image>
                        <TextBox BorderThickness="0" FontSize="20" FontFamily="Nunito Sans 10pt Normal" Text="Are you sure?" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,88,0,0"/>
                        <TextBox TextWrapping="Wrap" BorderThickness="0" Width="143" Height="30" FontSize="14" FontFamily="Nunito Sans 10pt Normal" Text="You will not be able to undo this action!" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,114,0,0" HorizontalContentAlignment="Center"/>
                        <Button Cursor="Hand" Click="Continue_Click" VerticalAlignment="Top" Width="143" Height="28" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Margin="0,158,0,0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                            <Button.Content>
                                <Border Padding="0" BorderThickness="0" CornerRadius="15" Background="#FF8861F7">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="Continue" FontSize="18" Foreground="#FFF3F3F3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                    </Grid>
                                </Border>
                            </Button.Content>
                        </Button>
                        <Button Cursor="Hand" Click="Close_Click" VerticalAlignment="Top" Width="143" Height="28" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Margin="0,198,0,0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                            <Button.Content>
                                <Border Padding="0" BorderThickness="1" CornerRadius="15" Background="#FFFDFEFF" BorderBrush="#FF8560F2">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="Cansel" FontSize="18" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                    </Grid>
                                </Border>
                            </Button.Content>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
    </Page>
    
</Window>
