<Page
    x:Class="VoiceX.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceX.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="White" Name="historyPage" Loaded="HistoryPage_Loaded">
    <Page.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border CornerRadius="6" Padding="4" Background="White"
            BorderThickness="1"
             BorderBrush="#FFC1BFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" x:Name="MainGrid" Width="245">
        <Grid Margin="0,45,0,38" >
            <Grid x:Name="PageContent">
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid VerticalAlignment="Top" MaxWidth="500" Height="45" Margin="10,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                    <Grid MaxWidth="500" Width="215" VerticalAlignment="Top" Margin="10,10,10,0" Height="25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Cursor="Hand" ToolTipService.ToolTip="{DynamicResource m_AllCall}" ToolTipService.Placement="Mouse" Grid.Column="0" MinWidth="20" GroupName="Filter" x:Name="AllCall" Checked="Filter_Checked" Background="Transparent" Height="25" HorizontalAlignment="Stretch" Padding="0,6,0,0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Center" Width="53.7">
                                <TextBlock RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" x:Name="AllText" Text="{DynamicResource m_All}" FontFamily="Nunito Sans 10pt Normal" FontSize="14" Foreground="#FF252422" HorizontalAlignment="Center"/>
                                <Border CornerRadius="1" x:Name="CheckAll" Height="2" Background="#FFC1BFFF" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Cursor="Hand" ToolTipService.ToolTip="{DynamicResource m_MissedCall}" ToolTipService.Placement="Mouse" Grid.Column="3" MinWidth="40" x:Name="IgnoreCall" GroupName="Filter" Checked="Filter_Checked" Height="25" HorizontalAlignment="Stretch">
                            <StackPanel Width="53.7">
                                <TextBlock RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" x:Name="MinusText" Text="{DynamicResource m_Missed}" FontFamily="Nunito Sans 10pt Normal" FontSize="14" Foreground="#FFA0A0A0" HorizontalAlignment="Center" Width="45"/>
                                <Border CornerRadius="1" x:Name="ChekIgnore" Height="2" VerticalAlignment="Stretch" Background="#FFF0F0FF"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Cursor="Hand" ToolTipService.ToolTip="{DynamicResource m_OutCall}" ToolTipService.Placement="Mouse" Grid.Column="2" x:Name="OutCall" GroupName="Filter" Checked="Filter_Checked" Height="25"  HorizontalAlignment="Stretch">
                            <StackPanel Width="53.7">
                                <TextBlock RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" x:Name="OutText" Text="{DynamicResource m_Outgoing}" FontFamily="Nunito Sans 10pt Normal" FontSize="14" Foreground="#FFA0A0A0" HorizontalAlignment="Center"/>
                                <Border CornerRadius="1" x:Name="CheckOut" Height="2" Background="#FFF0F0FF"  HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Cursor="Hand" ToolTipService.ToolTip="{DynamicResource m_Incall}" ToolTipService.Placement="Mouse" Grid.Column="1" x:Name="InCall" GroupName="Filter" MinWidth="40" Checked="Filter_Checked" Height="25" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" >
                            <StackPanel Width="53.7">
                                <TextBlock RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" x:Name="InText" Text="{DynamicResource m_Incoming}" FontFamily="Nunito Sans 10pt Normal" FontSize="14" Foreground="#FFA0A0A0" HorizontalAlignment="Center"/>
                                <Border CornerRadius="1" x:Name="ChekIn" Height="2" Background="#FFF0F0FF"  HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                    <Border RenderTransform="{DynamicResource GlobalFlip}" RenderTransformOrigin="{DynamicResource GlobalOrigin}" BorderThickness="0, 0, 0, 1" BorderBrush="#FFC1BFFF" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,35,0,0">
                        <Grid>
                            <TextBox BorderThickness="0" x:Name="Search"  MinHeight="26" TextChanged="Search_TextChanged" Width="225" BorderBrush="#FF8F8F8F" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="14" Height="25" Padding="6,0,6,0"/>
                            <Grid Height="15" x:Name="magnifyingGlass" Width="15" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,3">
                                <Border x:Name="magnifyingGlassLine" Background="#FFC1BFFF" Height="1.1" Width="6" CornerRadius="1" RenderTransformOrigin="0.5,0.5" Margin="8,8.6,0,0">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="45"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Border.RenderTransform>

                                </Border>
                                <Ellipse x:Name="magnifyingGlassEllipse" Fill="White" StrokeThickness="1" Width="10" Height="11" Stroke="#FFC1BFFF"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <ListBox ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Hidden" BorderThickness="0" Margin="0,66,0,0" x:Name="HistoryList" Background="White" Padding="0,0,10,0" Grid.RowSpan="2"/>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
