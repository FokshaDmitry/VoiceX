<Grid x:Class="VoiceX.Views.ControlPages.GeneralSettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VoiceX.Views.ControlPages"
      mc:Ignorable="d"
      Background="#FFFDFEFF" d:DesignHeight="375" d:DesignWidth="245">
    <Grid.Resources>
        <Style TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="50" Height="25">
                            <Border x:Name="SwitchBackground"
                            Width="27" Height="15"
                            CornerRadius="7"
                            Background="#FFFDFEFF"/>
                            <Border x:Name="SwitchThumb"
                            Width="12" Height="12"
                            CornerRadius="10"
                            Background="#FFBBBAFF"
                            Margin="-10,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>

                        <!-- Анимация -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBackground" Property="Background" Value="#FF6384FB"/>
                                <Setter TargetName="SwitchThumb" Property="Background" Value="#FFFDFEFF"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="10,0,0,0"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                     Storyboard.TargetProperty="X"
                                                     To="25" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="SwitchBackground" Property="Background" Value="#FFFDFEFF"/>
                                <Setter TargetName="SwitchThumb" Property="Background" Value="#FFBBBAFF"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="-10,0,0,0"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                     Storyboard.TargetProperty="X"
                                                     To="0" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand" Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Grid.Resources>

    <Grid x:Name="MainGrid" HorizontalAlignment="Stretch" VerticalAlignment="Top" Width="245" Margin="0,7,0,0">
        
        <Border BorderThickness="1" CornerRadius="5" Height="42" Margin="0,15,0,0" Width="230" VerticalAlignment="Top"  Background="#FFFEFEFF" HorizontalAlignment="Stretch"  BorderBrush="#FFECECF1" >
            <Grid>
                <Image Height="28" Width="28" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="7,0,0,0">
                    <Image.Source>
                        <BitmapImage UriSource="/Assets/Icone_v2/User-48.png" DecodePixelWidth="50" DecodePixelHeight="50"/>
                    </Image.Source>
                </Image>
                <TextBlock  FontFamily="Nunito Sans 10pt Normal" Text="Sunny Aveiro"   HorizontalAlignment="Left" x:Name="AccountFild" Margin="40,11,0,0"  VerticalAlignment="Top" FontSize="12" Foreground="#FF252422" Width="106"/>
                <Grid  x:Name="ActivGrid" VerticalAlignment="Bottom" Margin="41,0,66,5" HorizontalAlignment="Stretch" >
                    <TextBlock  x:Name="phoneNumber" FontFamily="Nunito Sans 10pt Normal" Text="{DynamicResource m_Active}"  VerticalAlignment="Center" FontSize="10" Foreground="#FF101010" HorizontalAlignment="Left" Margin="8,0,0,0" Width="98"/>
                    <Ellipse Height="6" x:Name="Activ"  Fill="#FFF31E38" VerticalAlignment="Center" Width="6" HorizontalAlignment="Left"/>
                </Grid>
                <Border Width="1" CornerRadius="0.5" Background="#FFC1BFFF" Height="26" HorizontalAlignment="Right" Margin="0,0,48,0" VerticalAlignment="Center"/>
                <Button Click="Global_Click" x:Name="Global" BorderThickness="0" Cursor="Hand"   Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,0,0" Margin="0,0,12,0">
                    <Button.Content>
                        <StackPanel HorizontalAlignment="Stretch">
                            <Grid>
                                <Image Height="22" Width="22" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Image.Source>
                                        <BitmapImage UriSource="/Assets/Icone_v2/Icon-Globe.png" DecodePixelWidth="50" DecodePixelHeight="50"/>
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </StackPanel>
                    </Button.Content>
                </Button>
                
            </Grid>

        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18,67,0,0" Height="14">
            <TextBlock FontFamily="/Assets/Fonts/Inter-Regular.ttf#Inter" x:Name="PbXText" Text="{DynamicResource m_PBX}" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="11"/>
            <TextBlock FontFamily="/Assets/Fonts/Inter-Regular.ttf#Inter" HorizontalAlignment="Left" x:Name="PbXNumber" Text="50" VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>
        <Border Width="213" CornerRadius="5" Height="68" Background="#FFE8D6FE" VerticalAlignment="Top" Margin="0,90,0,0">
            <Grid>
                <ToggleButton Click="SmartPhone_Toggled" Cursor="Hand" x:Name="SmartPhone" VerticalAlignment="Top" Width="49" HorizontalAlignment="Left" Height="26" Margin="0,5,0,0" />
                <ToggleButton Click="LopTop_Toggled" Cursor="Hand" x:Name="LopTop" VerticalAlignment="Top"  Margin="94,5,0,0" Width="45" HorizontalAlignment="Left" Padding="0,0,0,0" />
                <TextBlock Text="{DynamicResource m_App}" FontSize="12" FontFamily="Nunito Sans 10pt Normal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="14,0,0,8" Foreground="#FF6864D8"/>
                <TextBlock Text="{DynamicResource m_Phone}" FontSize="12" FontFamily="Nunito Sans 10pt Normal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="111,0,0,8" Foreground="#FF6864D8"/>
            </Grid>

        </Border>
        <Border Width="213" CornerRadius="5" Height="68" Background="#FFC5D2FF" VerticalAlignment="Top" Margin="0,175,0,0">
            <Grid>
                <ToggleButton Click="Tcp_Toggled" Cursor="Hand" x:Name="Tcp" VerticalAlignment="Top" Margin="0,5,0,0" Width="48" Height="27" HorizontalAlignment="Left" />
                <ToggleButton Click="Tls_Toggled" Cursor="Hand" x:Name="Tls" VerticalAlignment="Top" Margin="100,5,0,0" Width="46" HorizontalAlignment="Left" />
                <TextBlock Text="TCP" FontSize="12" FontFamily="Nunito Sans 10pt Normal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="14,0,0,8" Foreground="#FF6864D8"/>
                <TextBlock Text="UDP" FontSize="12" FontFamily="Nunito Sans 10pt Normal" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="111,0,0,8" Foreground="#FF6864D8"/>
            </Grid>
        </Border>
        <Image Width="45" Height="66" HorizontalAlignment="Left" Margin="65,80,0,0" VerticalAlignment="Top">
            <Image.Source>
                <BitmapImage UriSource="/Assets/Icone_v2/PC.png" DecodePixelWidth="470" DecodePixelHeight="650"/>
            </Image.Source>
        </Image>
        <Image Width="45"  Height="66" HorizontalAlignment="Left" Margin="65,170,0,0" VerticalAlignment="Top">
            <Image.Source>
                <BitmapImage UriSource="/Assets/Icone_v2/Folder.png" DecodePixelWidth="153" DecodePixelHeight="188"/>
            </Image.Source>
        </Image>
        <Image HorizontalAlignment="Left" Margin="167,80,0,0" VerticalAlignment="Top" Height="66">
            <Image.Source>
                <BitmapImage UriSource="/Assets/Icone_v2/LinePhone.png" DecodePixelWidth="200" DecodePixelHeight="240"/>
            </Image.Source>
        </Image>
        <Image Width="53" Height="66" HorizontalAlignment="Left" Margin="163,170,0,0" VerticalAlignment="Top">
            <Image.Source>
                <BitmapImage UriSource="/Assets/Icone_v2/Key.png" DecodePixelWidth="180" DecodePixelHeight="189"/>
            </Image.Source>
        </Image>
        <TextBlock HorizontalAlignment="Left" MinHeight="12" x:Name="Error" Margin="94,348,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="9" Foreground="#FFDF0505"/>
        <Border Visibility="Hidden" x:Name="GlobalWindow" CornerRadius="8" BorderThickness="1" Width="125" Height="78" VerticalAlignment="Top" Background="White" BorderBrush="#FFC1BFFF" Margin="13,52,0,0" HorizontalAlignment="Left">
            <Grid>
                <Button x:Name="Language" Click="Language_Click" BorderThickness="0" Cursor="Hand"   Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" Margin="12,12,0,0">
                    <Button.Content>
                        <StackPanel HorizontalAlignment="Stretch">
                            <Grid>
                                <Image Width="22" Height="22" HorizontalAlignment="Left">
                                    <Image.Source>
                                        <BitmapImage UriSource="/Assets/Icone_v2/Icon-Translate.png" DecodePixelWidth="50" DecodePixelHeight="50"/>
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="{DynamicResource m_Language}" FontSize="16" FontFamily="Nunito Sans 10pt Normal" Foreground="#FF252422" Margin="24,0,0,0" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button BorderThickness="0" Cursor="Hand" x:Name="Exit"  Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" Margin="12,44,0,0">
                    <Button.Content>
                        <StackPanel HorizontalAlignment="Stretch">
                            <Grid>
                                <Image x:Name="ExitIcone" Width="22" Height="22" HorizontalAlignment="Left">
                                    <Image.Source>
                                        <BitmapImage UriSource="/Assets/Icone_v2/Icon-SignOut.png" DecodePixelWidth="50" DecodePixelHeight="50"/>
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="{DynamicResource m_LogOut}" FontSize="16" FontFamily="Nunito Sans 10pt Normal" Foreground="#FF252422" Margin="24,0,0,0" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Grid>
