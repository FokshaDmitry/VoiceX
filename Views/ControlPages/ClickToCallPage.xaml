<Page
    x:Class="VoiceX.Views.ControlPages.ClickToCallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceX.Views.ControlPages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="White" Name="ClickToCall" Loaded="ClickToCall_Loaded" MaxWidth="500">
    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand" Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border CornerRadius="6" Padding="4" Background="White"
            BorderThickness="1"
             BorderBrush="#FFC1BFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid VerticalAlignment="Top">
            <TextBlock Text="Dail Transform" x:Name="DailText" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFB5B5B5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,5,0,0" FontSize="14"/>
            <Border Height="32" Margin="16,27,16,0" CornerRadius="4" BorderBrush="#FFD1D0FF" Background="Transparent" BorderThickness="1" Width="213">
                <TextBox BorderThickness="0" ToolTip="Change control combination" Cursor="Hand" ToolTipService.ToolTip="Change control combination" ToolTipService.Placement="Mouse" Background="Transparent" x:Name="HotKeyBox" IsReadOnly="True" KeyDown="HotKeyBox_KeyDown" KeyUp="HotKeyBox_KeyUp" FontFamily="Nunito Sans 10pt Normal" HorizontalAlignment="Stretch"  TextWrapping="Wrap" VerticalAlignment="Top" FontSize="14" Height="24" MinWidth="150" FontWeight="Normal" Padding="6,4,6,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" Foreground="#FF252422" BorderBrush="#FFBBBAFF" Margin="0,4,0,0"/>
            </Border>
        </Grid>
        <Border CornerRadius="150" BorderThickness="0" Height="1" Width="213" Background="#FFC3B1FD" VerticalAlignment="Top" Margin="9,80,9,0" Grid.ColumnSpan="2"/>
        <Grid Margin="0,92,0,0" Height="250" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="10*"/>
            </Grid.RowDefinitions>
            <Grid x:Name="SectionGrig" Grid.Row="0">
                <TextBlock Text="Enter Data" Margin="16,0,0,0" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFB5B5B5"/>
                <Button Cursor="Hand" Click="Remove_Click" Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,0,16,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                    <Button.Content>
                        <Image>
                            <Image.Source>
                                <BitmapImage UriSource="/Assets/Icone_v2/Icon-TrashSimple.png" DecodePixelWidth="40" DecodePixelHeight="40"/>
                            </Image.Source>
                        </Image>
                    </Button.Content>
                </Button>
                
                
                <Button Cursor="Hand" Background="Transparent" Click="ServerButton_Click" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" Height="15" Padding="0,0,0,0" BorderBrush="Transparent" Width="15" HorizontalAlignment="Right" Margin="0,0,38,0" VerticalAlignment="Top">
                    <Button.Content>
                        <Image>
                            <Image.Source>
                                <BitmapImage UriSource="/Assets/Icone_v2/Icon-File.png" DecodePixelWidth="40" DecodePixelHeight="40"/>
                            </Image.Source>
                        </Image>
                    </Button.Content>
                </Button>
            </Grid>
            <Grid x:Name="ListViewGrid" Grid.Row="1" Margin="16,0,5,0">
                <ListBox ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Hidden" BorderThickness="0" x:Name="RegExList" Background="Transparent" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalAlignment="Center" Height="215" VerticalAlignment="Top" SelectionChanged="RegExList_SelectionChanged">

                </ListBox>
            </Grid>

        </Grid>

    </Grid>
</Page>
