<Page x:Class="VoiceX.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VoiceX.Views"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="245" Loaded="ControlPage_Loaded" >
    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border CornerRadius="6" Padding="4" Background="White"
                    BorderThickness="1"
                     BorderBrush="#FFC1BFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Storyboard x:Key="SlideUpAnimation">
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                         Storyboard.TargetProperty="Y"
                         From="400" To="0"
                         Duration="0:0:0.5"
                         DecelerationRatio="0.5"/>
        </Storyboard>
        <Storyboard x:Key="SlideLeftAnimation">
            <DoubleAnimation Storyboard.TargetName="SlideLeftTransform"
                         Storyboard.TargetProperty="X"
                         From="400" To="0"
                         Duration="0:0:0.5"
                         DecelerationRatio="0.9"/>
        </Storyboard>
    </Page.Resources>
    <Grid>

        <Grid x:Name="ControlMainPage" Height="420" Width="245" Background="White">
            <Grid Margin="0,45,0,0" Cursor="Hand">
                <Grid x:Name="PageContent" Cursor="Hand">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="25" MaxWidth="500" Margin="12,7,12,0">
                        <Grid.Resources>
                            <Style TargetType="RadioButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <StackPanel Orientation="Horizontal">
                                                <ContentPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Grid.Resources>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <RadioButton  Cursor="Hand" ToolTipService.ToolTip="General" ToolTipService.Placement="Mouse" Grid.Column="0" IsChecked="True" GroupName="Filter" Name="General"  MinWidth="55" Background="Transparent" MinHeight="25" HorizontalAlignment="Stretch">
                            <StackPanel Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" Width="78.3" Height="25">
                                <TextBlock Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" x:Name="GeneralText" Text="General" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Margin="0,3,0,7" Foreground="#FF252422"/>
                                <Border Height="3" CornerRadius="0, 0, 0, 1.5" Background="#FFF0F0FF" Margin="0,-7,0,0"/>
                                <Border x:Name="GeneralCheck" Height="3" CornerRadius="1.5" Background="#FFC1BFFF" Margin="0,-7,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Cursor="Hand" ToolTipService.ToolTip="Addition" ToolTipService.Placement="Mouse" Grid.Column="2" MinWidth="55" MinHeight="25" Name="Addition" GroupName="Filter" HorizontalAlignment="Stretch">
                            <StackPanel Width="78">
                                <TextBlock Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" x:Name="AdditionText" Text="Addition" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Margin="0,3,0,0" Foreground="#FF252422"/>
                                <Border Height="3" CornerRadius="0, 0, 1.5, 0" VerticalAlignment="Stretch" Background="#FFF0F0FF" Margin="0,2,0,0"/>
                                <Border Visibility="Collapsed" x:Name="AdditionChek"  Height="3" CornerRadius="1.5" VerticalAlignment="Stretch" Background="#FFC1BFFF" Margin="0,-3,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Cursor="Hand" ToolTipService.ToolTip="Click To Call" ToolTipService.Placement="Mouse" Grid.Column="1" Name="C2C" GroupName="Filter"  MinHeight="25" MinWidth="55" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" >
                            <StackPanel Cursor="Hand" Width="78.3">
                                <TextBlock FontFamily="Nunito Sans 10pt Normal" Cursor="Hand" x:Name="C2CText" Text="C2C" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Margin="0,3,0,0" Foreground="#FF252422"/>
                                <Border Cursor="Hand" Height="3" VerticalAlignment="Stretch" Background="#FFF0F0FF" Margin="0,2,0,0"/>
                                <Border Visibility="Collapsed" Cursor="Hand" x:Name="C2CCheck" Height="3" CornerRadius="1.5" VerticalAlignment="Stretch" Background="#FFC1BFFF" Margin="0,-3,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                    <Frame NavigationUIVisibility="Hidden" x:Name="ContentControl" HorizontalAlignment="Stretch" Cursor="Hand" VerticalAlignment="Stretch" Margin="0,35,0,0" MaxWidth="500" MinWidth="165">
                        <Frame.RenderTransform>
                            <TranslateTransform x:Name="SlideLeftTransform"/>
                        </Frame.RenderTransform>
                    </Frame>
                </Grid>
            </Grid>
        </Grid>

        <Frame NavigationUIVisibility="Hidden"  x:Name="MainFrame">
            <Frame.RenderTransform>
                <TranslateTransform x:Name="SlideTransform"/>
            </Frame.RenderTransform>
        </Frame>
