<Grid x:Class="VoiceX.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VoiceX.Views"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="245" Loaded="ControlPage_Loaded" >
    <Grid.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border  Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Grid.Resources>
    <Grid x:Name="ControlMainPage" Height="420" Width="245" Background="White">
        <Grid Margin="0,45,0,0" Cursor="Hand">
            <Grid x:Name="PageContent" Cursor="Hand">
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="25" MaxWidth="500" Margin="5,7,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <RadioButton  Cursor="Hand" ToolTipService.ToolTip="General" ToolTipService.Placement="Mouse" Grid.Column="0" IsChecked="True" GroupName="Filter" Name="General"  MinWidth="55" Background="Transparent" MinHeight="25" HorizontalAlignment="Stretch">
                        <StackPanel Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" Width="79" Height="25">
                            <TextBlock Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" x:Name="GeneralText" Text="General" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Margin="0,3,0,7" Foreground="#FF252422"/>
                            <Grid x:Name="GeneralCheck" Height="2" Background="#FF8A63FB" Margin="0,-6,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Cursor="Hand" ToolTipService.ToolTip="Addition" ToolTipService.Placement="Mouse" Grid.Column="2" MinWidth="55" MinHeight="25" Name="Addition" GroupName="Filter" HorizontalAlignment="Stretch">
                        <StackPanel Width="78">
                            <TextBlock Cursor="Hand" FontFamily="Nunito Sans 10pt Normal" x:Name="AdditionText" Text="Addition" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Margin="0,3,0,0" Foreground="#FF252422"/>
                            <Grid x:Name="AdditionChek" Height="2" VerticalAlignment="Stretch" Background="#FFFDFEFF" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Cursor="Hand" ToolTipService.ToolTip="Click To Call" ToolTipService.Placement="Mouse" Grid.Column="1" Name="C2C" GroupName="Filter"  MinHeight="25" MinWidth="55" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" >
                        <StackPanel Cursor="Hand" Width="78">
                            <TextBlock FontFamily="Nunito Sans 10pt Normal" Cursor="Hand" x:Name="C2CText" Text="C2C" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Margin="0,3,0,0" Foreground="#FF252422"/>
                            <Grid Cursor="Hand" x:Name="C2CCheck" Height="2" VerticalAlignment="Stretch" Background="#FFFDFEFF" Margin="0,3,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </Grid>
                <Grid x:Name="ContentControl" HorizontalAlignment="Stretch" Cursor="Hand" VerticalAlignment="Stretch" Margin="0,35,0,0" MaxWidth="500" MinWidth="165"  >

                </Grid>
            </Grid>
            
        </Grid>
        
    </Grid>
    <Grid x:Name="Menu" VerticalAlignment="Bottom" Margin="0,0,0,-50">
        <Border CornerRadius="15, 15, 0, 0" Height="100" VerticalAlignment="Bottom" Background="#FFC3B1FD">
            <Grid>
                <Button BorderThickness="0" Name="Contacts" Cursor="Hand" Margin="12,10,0,0" Click="Navigate_Click" Width="18" Padding="0,0,0,0" Height="18" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Button.Content>
                        <Border Width="18" Height="18" BorderThickness="0" BorderBrush="Transparent">
                            <Border.Background>
                                <ImageBrush>
                                    <ImageBrush.ImageSource>
                                        <BitmapImage UriSource="/Assets/Icone_v2/contactsNavigate.png" DecodePixelWidth="70" DecodePixelHeight="70"/>
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Button.Content>

                </Button>
                <Button Background="Transparent" BorderThickness="0" Name="Phone" Margin="70,10,157,0" Click="Navigate_Click"  Padding="0,0,0,0" Height="18" VerticalAlignment="Top">
                    <Button.Content>
                        <Border Width="18" Height="18" BorderThickness="0" BorderBrush="Transparent">
                            <Border.Background>
                                <ImageBrush>
                                    <ImageBrush.ImageSource>
                                        <BitmapImage UriSource="/Assets/Icone_v2/phoneNavigate.png" DecodePixelWidth="80" DecodePixelHeight="80"/>
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Button.Content>
                </Button>
                <Button BorderThickness="0" Name="History"  VerticalAlignment="Top" Margin="166,10,61,0" Click="Navigate_Click"  Width="18" Padding="0,0,0,0" Height="18">
                    <Button.Content>
                        <Border Width="18" Height="18" BorderThickness="0" BorderBrush="Transparent">
                            <Border.Background>
                                <ImageBrush>
                                    <ImageBrush.ImageSource>
                                        <BitmapImage UriSource="/Assets/Icone_v2/historyNavigate.png" DecodePixelWidth="80" DecodePixelHeight="80"/>
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Button.Content>
                </Button>
                <Button BorderThickness="0" Name="Fax" Cursor="Hand" VerticalAlignment="Top" Margin="19,54,208,0" Click="Navigate_Click"  Width="18"  Padding="0,0,0,0" Height="18">
                    <Button.Content>
                        <Border Width="18" Height="18" BorderThickness="0" BorderBrush="Transparent">
                            <Border.Background>
                                <ImageBrush>
                                    <ImageBrush.ImageSource>
                                        <BitmapImage UriSource="/Assets/Icone_v2/faxNavigate.png" DecodePixelWidth="50" DecodePixelHeight="50"/>
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Button.Content>
                </Button>
                <Button BorderThickness="0" Cursor="Hand" x:Name="MenuMore" Click="Menu_Click"  Background="Transparent" Width="18"  Padding="0,0,0,0" Height="18" VerticalAlignment="Top" Margin="207,10,20,0">
                    <Button.Content>
                        <StackPanel>
                            <Grid x:Name="Butter" Height="13">
                                <Rectangle Fill="#FFF4F2FF" Width="15" Height="1.5"  VerticalAlignment="Top"/>
                                <Rectangle Fill="#FFF4F2FF" Width="15" Height="1.5" HorizontalAlignment="Center"/>
                                <Rectangle Fill="#FFF4F2FF" Width="15" Height="1.5" VerticalAlignment="Bottom"/>
                            </Grid>
                            <Grid Visibility="Collapsed" x:Name="Cross">
                                <Rectangle Fill="#FFF4F2FF" Width="15" Height="1.5" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="-45"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>

                                <Rectangle Fill="#FFF4F2FF" Width="15" Height="1.5" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="45"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button BorderThickness="0" Name="HotKeys" Cursor="Hand" VerticalAlignment="Top" Margin="70,54,157,0" Click="Navigate_Click"  Width="18" Padding="0,0,0,0" Height="18">
                    <Button.Content>
                        <Border Width="18" Height="18" BorderThickness="0" BorderBrush="Transparent">
                            <Border.Background>
                                <ImageBrush>
                                    <ImageBrush.ImageSource>
                                        <BitmapImage UriSource="/Assets/Icone_v2/Keyboard.png" DecodePixelWidth="50" DecodePixelHeight="50"/>
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Button.Content>
                </Button>
                <TextBlock Text="HotKeys" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFFDFEFF" FontSize="12" Margin="57.5,75,0,0"/>
                <TextBlock Text="Clients" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFFDFEFF" FontSize="12" Margin="111,30,0,0"/>
                <TextBlock Text="Dialpad" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFFDFEFF" FontSize="12" Margin="60,30,0,0"/>
                <TextBlock Text="History" HorizontalAlignment="Right" VerticalAlignment="Top" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFFDFEFF" FontSize="12" Margin="0,30,51,0"/>
                <TextBlock Text="Fax" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFFDFEFF" FontSize="12" Margin="20,75,0,0"/>
                <TextBlock Text="More" HorizontalAlignment="Right" VerticalAlignment="Top" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFFDFEFF" FontSize="12" Margin="0,30,15,0" Grid.ColumnSpan="2"/>
            </Grid>

        </Border>
        <Border BorderThickness="2" BorderBrush="White" CornerRadius="22" Background="#FFC3B1FD" Width="45" Height="45" VerticalAlignment="Top" Margin="10,-13,0,10" HorizontalAlignment="Left" RenderTransformOrigin="1,0" >
            <Image Source="/Assets/Icone_v2/homeNavigate.png" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
    <Grid Cursor="Hand"  VerticalAlignment="Top" Height="45" >
        <Grid.Background>
            <ImageBrush>
                <ImageBrush.ImageSource>
                    <BitmapImage UriSource="/Assets/Icone_v2/BackgroundTopElement.png" DecodePixelWidth="350" DecodePixelHeight="400"/>
                </ImageBrush.ImageSource>
            </ImageBrush>
        </Grid.Background>
        <Image Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,2,0,0" Width="55">
            <Image.Source>
                <BitmapImage UriSource="/Assets/Icone_v2/TopLogo.png" DecodePixelWidth="200" DecodePixelHeight="90"/>
            </Image.Source>
        </Image>
        <Button Cursor="Hand" BorderThickness="0" ToolTipService.ToolTip="Pauses" ToolTipService.Placement="Mouse" x:Name="Pauses" Click="Pauses_Click" Height="30" Width="30" Background="Transparent" Padding="0,0,0,0" HorizontalAlignment="Right" Margin="0,0,16,0">
            <Button.Content>
                <Border CornerRadius="20" Height="28" Width="28"  Background="#FFFDFEFF" >
                    <Image Source="/Assets/Icone_v2/Coffee.png" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Button.Content>
        </Button>
    </Grid>
    <Grid Visibility="Collapsed" x:Name="PausesFild" Background="#CC202244">
        <Grid Background="White" Width="204" Height="246">
            <Button Cursor="Hand" Name="Close" Click="Close_Click" Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,5,6,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                <Button.Content>
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                        <Rectangle RadiusX="0.5" RadiusY="0.5" Width="9.4" Height="1" Fill="#FF252422" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="45"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle RadiusX="0.5" RadiusY="0.5" Width="9.4" Height="1" Fill="#FF252422" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-45"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                    </Grid>
                </Button.Content>
            </Button>
            <TextBlock Text="Pauses" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,18,0,0" FontSize="20" FontFamily="Nunito Sans 10pt Normal"/>
            <Button Cursor="Hand"   Content="Save" x:Name="Save" Click="Save_Click" VerticalAlignment="Bottom" Margin="0,0,10,15" Background="#FF8A63FB" Width="148" Height="32" FontSize="18" FontFamily="Jost" Foreground="#E4FFFFFF" Padding="0,0,0,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
            <ListBox BorderThickness="0" SelectionChanged="PauseList_SelectionChanged" x:Name="PauseList" Height="137" Margin="0,0,0,8" Width="187" Background="White" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
    <Grid Visibility="Collapsed" x:Name="NumpadFild" Background="#CC202244" Margin="-6,0,-6,0">
        <Border CornerRadius="12" Background="White" Width="204" Height="374">
            <Grid>
                <Button Cursor="Hand" Click="Close_Click" Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,5,6,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                    <Button.Content>
                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Rectangle RadiusX="0.5" RadiusY="0.5" Width="9.4" Height="1" Fill="#FF898989" RenderTransformOrigin="0.5,0.5">
                                <Rectangle.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="45"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Rectangle.RenderTransform>

                            </Rectangle>
                            <Rectangle RadiusX="0.5" RadiusY="0.5" Width="9.4" Height="1" Fill="#FF898989" RenderTransformOrigin="0.5,0.5">
                                <Rectangle.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="-45"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Rectangle.RenderTransform>

                            </Rectangle>
                        </Grid>
                    </Button.Content>
                </Button>
                <TextBlock x:Name="TitleNumpad" Text="Add contacts" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,18,0,0" FontSize="20" FontFamily="Nunito Sans 10pt Normal"/>
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="25" MaxWidth="500" Margin="5,53,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Cursor="Hand" Grid.Column="0" IsChecked="True" GroupName="Filter" Name="Keypad" Checked="Filter_Checked_1" MinWidth="55" Background="Transparent" MinHeight="25" HorizontalAlignment="Stretch">
                        <StackPanel Margin="0,4,0,4">
                            <TextBlock FontFamily="Nunito Sans 10pt Normal" x:Name="KeyText" Text="Keypad" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Margin="15,1,0,0" Foreground="#FF252422"/>
                            <Grid x:Name="GeneralCheck1" Height="1.5" Background="#FF8A63FB" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Cursor="Hand" Grid.Column="2" MinWidth="55" MinHeight="25" Name="Contactspad" GroupName="Filter" Checked="Filter_Checked_1" HorizontalAlignment="Stretch">
                        <StackPanel Margin="0,4,0,4">
                            <TextBlock FontFamily="Nunito Sans 10pt Normal" x:Name="ContactspadText" Text="Contacts" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Margin="15,1,0,0" Foreground="#FF252422"/>
                            <Grid x:Name="AdditionChek1" Height="1.5" VerticalAlignment="Stretch" Background="#FFFDFEFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </Grid>
                <Grid Margin="0,93,0,0">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Top" >
                        <TextBox  x:Name="KeypadFild" TextAlignment="Center" BorderThickness="0,0,0,1" MinHeight="23"  FontFamily="Nunito Sans 10pt Normal"   Canvas.Left="2" Margin="10,0,10,0" BorderBrush="#FFC2C3C3" FontSize="14" Height="23" VerticalAlignment="Top" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Width="189" Padding="10,0,6,0" Background="#FFFDFEFF"/>
                        <Button BorderBrush="Transparent" BorderThickness="0" Visibility="Collapsed" Click="BackspaceNum_Click" Height="15" Background="Transparent" Padding="-2,-2,-2,-2" Width="15" x:Name="BackspaceNum" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,2" >
                            <Button.Content>
                                <Image Height="15" Width="15" Stretch="Fill">
                                    <Image.Source>
                                        <BitmapImage UriSource="/Assets/Icone_v2/Backspace.png" DecodePixelWidth="50" DecodePixelHeight="50"/>
                                    </Image.Source>
                                </Image>
                            </Button.Content>
                        </Button>
                    </Grid>
                    <Grid  Width="146" Margin="0,35,0,0">
                        <Button BorderThickness="0" Cursor="Hand" Name="Num" Click="Num_Click" Content="1" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Grid.RowSpan="2" HorizontalAlignment="Left"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="2" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" HorizontalAlignment="Center" Grid.RowSpan="2"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="3" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" HorizontalAlignment="Right" Grid.RowSpan="2"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="4" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,48,0,0" Grid.Row="1" HorizontalAlignment="Left"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="5" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,48,0,0" HorizontalAlignment="Center" Grid.Row="1"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="6" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,48,0,0" HorizontalAlignment="Right" Grid.Row="1"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="7" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,96,0,0" Grid.Row="1" HorizontalAlignment="Left"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="8" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,96,0,0" HorizontalAlignment="Center" Grid.Row="1"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="9" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,96,0,0" HorizontalAlignment="Right" Grid.Row="1"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="*" VerticalAlignment="Top" Width="36" Height="36" Background="Transparent" FontSize="44" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,5,0,0" UseLayoutRounding="False" Margin="0,144,0,0" Grid.Row="1" HorizontalAlignment="Left"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="0" VerticalAlignment="Top" Width="36" Height="36" Background="#FFF4F4FF" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,144,0,0" HorizontalAlignment="Center" Grid.Row="1"/>
                        <Button BorderThickness="0" Cursor="Hand" Click="Num_Click" Content="#" VerticalAlignment="Top" Width="36" Height="36" Background="Transparent" FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,144,0,0" HorizontalAlignment="Right" Grid.Row="1"/>
                        <Button BorderThickness="0" Cursor="Hand" Name="AddContact" Click="AddContact_Click" VerticalAlignment="Top" Width="38" Height="38"  FontSize="24" FontFamily="Nunito Sans 10pt Normal" FontWeight="Normal" Padding="0,0,0,0" UseLayoutRounding="False" Margin="0,190,0,0" HorizontalAlignment="Center" Grid.Row="1">
                            <Button.Content >
                                <Border CornerRadius="50" Width="38" Height="38" Background="#FF06D665" >
                                    <Image Width="18" Height="18">
                                        <Image.Source>
                                            <BitmapImage UriSource="/Assets/Icone_v2/phoneNavigate.png" DecodePixelWidth="60" DecodePixelHeight="60"/>
                                        </Image.Source>
                                    </Image>
                                </Border>
                            </Button.Content>
                        </Button>
                    </Grid>
                </Grid>
                <Grid Visibility="Collapsed" x:Name="ContactListPad" Margin="0,93,0,0" Background="White">
                    <Grid VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBox BorderThickness="0, 0, 0, 1" x:Name="Search"  MinHeight="26" Width="172" BorderBrush="#FFC2C3C3" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="11" Height="25" Padding="10,5,20,5"/>
                        <Grid Height="15" x:Name="magnifyingGlass" Width="15" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,3">
                            <Rectangle x:Name="magnifyingGlassLine" Fill="#FF898989" Height="1.1" Width="6" RadiusX="1" RadiusY="1" RenderTransformOrigin="0.5,0.5" Margin="8,8.6,0,0">
                                <Rectangle.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="45"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Rectangle.RenderTransform>

                            </Rectangle>
                            <Ellipse x:Name="magnifyingGlassEllipse" Fill="White" StrokeThickness="1" Width="10" Height="11" Stroke="#FF898989"/>
                        </Grid>
                    </Grid>
                    <Button Cursor="Hand" Name="AddContacts" ToolTipService.ToolTip="Send Fax" ToolTipService.Placement="Mouse" Grid.Column="1" Click="AddContacts_Click" VerticalAlignment="Top" Margin="0,240,0,0" Background="#FF8A63FB" Width="124" Height="32" FontSize="18" FontFamily="Jost" Foreground="#E4FFFFFF" Padding="0,0,0,0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalAlignment="Center" FontWeight="Bold">
                        <Button.Content>
                            <Border CornerRadius="20" Background="#FF8A63FB" Height="32" Width="124" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Add" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Button.Content>
                    </Button>
                    <ListBox BorderThickness="0" Width="172" x:Name="ContactsList" MaxWidth="500" Margin="0,40,0,50" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White" Padding="0,0,10,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
    <Grid x:Name="KeyPad" Visibility="Collapsed" Background="#CC202244" Margin="-5,0,-5,0" >
        <Border CornerRadius="12" Background="White" Width="204" Height="294">
            <Grid>
                <Button Cursor="Hand" Click="Close_Click" Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,5,6,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
