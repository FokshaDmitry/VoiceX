                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.Resources>
                            <Style TargetType="RadioButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ContentPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Grid.Resources>
                        <RadioButton Cursor="Hand" Grid.Column="0" IsChecked="True" GroupName="Filter" Name="Keypad" Checked="Filter_Checked_1" MinWidth="55" Background="Transparent" MinHeight="25" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                            <StackPanel Margin="0,4,0,4">
                                <TextBlock FontFamily="Nunito Sans 10pt Normal" x:Name="KeyText" Text="Keypad" FontSize="16" Margin="0,-3,0,0" Foreground="#FF252422"/>
                                <Grid x:Name="GeneralCheck1" Height="1.5" Background="#FF8A63FB" Margin="0,-1,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Cursor="Hand" Grid.Column="2" MinWidth="55" MinHeight="25" Name="Contactspad" GroupName="Filter" Checked="Filter_Checked_1" HorizontalAlignment="Stretch">
                            <StackPanel Margin="0,4,0,4">
                                <TextBlock FontFamily="Nunito Sans 10pt Normal" x:Name="ContactspadText" Text="Contacts" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Margin="0,-3,0,0" Foreground="#FF252422"/>
                                <Grid x:Name="AdditionChek1" Height="1.5" VerticalAlignment="Stretch" Background="#FFFDFEFF" Margin="0,-1,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                    <Grid Margin="0,93,0,0">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Top" >
                            <TextBox TextChanged="KeypadFild_TextChanged" x:Name="KeypadFild" TextAlignment="Center" BorderThickness="0,0,0,1" MinHeight="23"  FontFamily="Nunito Sans 10pt Normal" Canvas.Left="2" Margin="10,0,10,0" BorderBrush="#FFC2C3C3" FontSize="14" Height="23" VerticalAlignment="Top" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Width="189" Padding="10,0,6,0" Background="#FFFDFEFF"/>
                            <Button BorderBrush="Transparent" BorderThickness="0" Visibility="Collapsed" Click="BackspaceNum_Click" Height="15" Background="Transparent" Padding="-2,-2,-2,-2" Width="15" x:Name="BackspaceNum" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,2" >
                                <Button.Content>
                                    <Image Height="15" Width="15" Stretch="Fill">
                                        <Image.Source>
                                            <BitmapImage UriSource="/Assets/Icone_v2/Backspace.png" DecodePixelWidth="50" DecodePixelHeight="50"/>
                                        </Image.Source>
                                    </Image>
                                </Button.Content>
                            </Button>
                        </Grid>
                        <Grid  Width="146" Margin="0,35,0,0">
                            <Grid.Resources>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Cursor="Hand" Background="#FFF4F4FF" CornerRadius="50">
