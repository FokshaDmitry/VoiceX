                        <Button.Content>
                            <Border CornerRadius="6" Background="#FFE5E5FF">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="Save" FontFamily="Bahnschrift Light" Foreground="#FF7B76FF" />
                                </Grid>
                            </Border>
                        </Button.Content>
