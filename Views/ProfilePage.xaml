                        </Canvas>
                    </Button.Content>
                </Button>
            </Grid>
        </Grid>
        <Grid Cursor="Hand"  VerticalAlignment="Top" Height="45" >
            <Grid.Background>
                <ImageBrush>
                    <ImageBrush.ImageSource>
                        <BitmapImage UriSource="/Assets/Icone_v2/BackgroundTopElement.png" DecodePixelWidth="350" DecodePixelHeight="400"/>
                    </ImageBrush.ImageSource>
                </ImageBrush>
            </Grid.Background>
            <Image Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,2,0,0" Width="55">
                <Image.Source>
                    <BitmapImage UriSource="/Assets/Icone_v2/TopLogo.png" DecodePixelWidth="200" DecodePixelHeight="90"/>
                </Image.Source>
            </Image>
            <Button Cursor="Hand" BorderThickness="0" ToolTipService.ToolTip="Pauses" ToolTipService.Placement="Mouse" x:Name="Pauses" Click="Pauses_Click" Height="30" Width="30" Background="Transparent" Padding="0,0,0,0" HorizontalAlignment="Right" Margin="0,0,16,0">
                <Button.Content>
                    <Border BorderThickness="1" BorderBrush="#FFC3B1FD" CornerRadius="20" Height="28" Width="28"  Background="#FFFDFEFF" >
                        <Image Source="/Assets/Icone_v2/Coffee.png" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Button.Content>
            </Button>
        </Grid>
        <Grid Visibility="Collapsed" x:Name="PausesFild" Background="#999692ED">
            <Border CornerRadius="12" Background="White" Width="204" Height="246">
                <Grid>
                    <Button Cursor="Hand" Name="Close" Click="Close_Click" Height="16" Padding="0,0,0,0" BorderBrush="Transparent" Width="16" Background="Transparent" HorizontalAlignment="Right" Margin="0,12,12,0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Top">
                        <Button.Content>
                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                                <Rectangle RadiusX="0.5" RadiusY="0.5" Width="12" Height="1" Fill="#FFADABFF" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="45"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                <Rectangle RadiusX="0.5" RadiusY="0.5" Width="12" Height="1" Fill="#FFADABFF" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="-45"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>

                            </Grid>
                        </Button.Content>
                    </Button>
                    <TextBlock Text="Pauses" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="9,9,0,0" FontSize="20" FontFamily="Nunito Sans 10pt Normal" Foreground="#FFADABFF"/>
