                <Button Background="Transparent" ToolTip="Contacts" BorderThickness="0" x:Name="SecondMenuButton" Margin="65,22,0,0" Click="Navigate_Click"  Padding="0,0,0,0" Height="22" VerticalAlignment="Top" HorizontalAlignment="Left">
                    <Button.Content>
                        <Border Width="22" Height="22" BorderThickness="0" BorderBrush="Transparent">
                            <Border.Background>
                                <ImageBrush>
                                    <ImageBrush.ImageSource>
                                        <BitmapImage x:Name="SecondMenuImage" UriSource="/Assets/Icone_v2/MenuItems/Contacts.png" DecodePixelWidth="80" DecodePixelHeight="80"/>
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Button.Content>
                </Button>
                <Button BorderThickness="0" ToolTip="History" x:Name="ThirdMenuButton"  VerticalAlignment="Top" Margin="0,22,65,0" Click="Navigate_Click"  Width="22" Padding="0,0,0,0" Height="22" HorizontalAlignment="Right">
                    <Button.Content>
                        <Border Width="22" Height="22" BorderThickness="0" BorderBrush="Transparent">
                            <Border.Background>
                                <ImageBrush>
                                    <ImageBrush.ImageSource>
                                        <BitmapImage x:Name="ThirdMenuImage" UriSource="/Assets/Icone_v2/MenuItems/History.png" DecodePixelWidth="80" DecodePixelHeight="80"/>
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Button.Content>
                </Button>
                <Button BorderThickness="0" ToolTip="Contacts" x:Name="FourMenuButton"  VerticalAlignment="Top" Margin="0,22,20,0" Click="Navigate_Click"  Width="22" Padding="0,0,0,0" Height="22" HorizontalAlignment="Right">
                    <Button.Content>
                        <Border Width="22" Height="22" BorderThickness="0" BorderBrush="Transparent">
                            <Border.Background>
                                <ImageBrush>
                                    <ImageBrush.ImageSource>
                                        <BitmapImage x:Name="FourMenuImage" UriSource="/Assets/Icone_v2/MenuItems/Contacts.png" DecodePixelWidth="80" DecodePixelHeight="80"/>
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>
                    </Button.Content>
                </Button>
                <Button BorderThickness="0" Cursor="Hand" x:Name="MoreRight" Click="Scroll_Click"  Background="Transparent" Width="22"  Padding="0,0,0,0" Height="22" VerticalAlignment="Top" Margin="0,22,20,0" HorizontalAlignment="Right">
                    <Button.Resources>
                        <Style x:Key="HoverablePathStyle" TargetType="Path">
                            <Setter Property="Fill" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Fill" Value="#FF7B76FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
