<Page x:Class="VoiceX.Views.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VoiceX.Views"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="245">
    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFE5E5FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border  Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="MainGrid" Width="245" Height="420" Background="#FFEBE2FF" >
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Background" Value="#FFE5E5FF"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="BorderThickness" Value="0"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#FFE5E5FF" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Отключаем изменение цвета при наведении -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#A459FC"/>
                        <!-- Оставляем тот же цвет -->
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <Grid >
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFC1BFFF"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Rectangle VerticalAlignment="Top" Margin="10,20,10,0" Height="231">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="/assets/icone_v2/illustration.png"/>
                </Rectangle.Fill>
            </Rectangle>
            <Button Width="220" Height="38" Margin="0,355,0,0" Background="#FFE5E5FF" VerticalAlignment="Top" HorizontalAlignment="Center" Cursor="Hand" BorderThickness="0" Padding="0" FontFamily="Nunito Sans 10pt Normal" Content="Continue" x:Name="Send" Click="Button_Send" Foreground="#FF7B76FF" />

            <Grid Background="Transparent" VerticalAlignment="Top" Margin="0,330,0,0" HorizontalAlignment="Center">
                <CheckBox  x:Name="Select" Click="Select_Click" MinWidth="10" FontFamily="/Assets/Fonts/Inter-Regular.ttf#Inter" MinHeight="10" VerticalAlignment="Stretch" Foreground="#FF5C66BD" FontSize="6" HorizontalAlignment="Left" Background="Transparent"/>
                <TextBlock x:Name="MyComputer" Text="This is my computer" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="22,0,0,0" FontSize="14" Foreground="#FF252422" FontFamily="Nunito Sans 10pt Normal"/>
            </Grid>
            <Grid VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,256,0,0">
                <Border Background="White" CornerRadius="6" BorderThickness="1" Padding="2" MinWidth="20" MinHeight="20" VerticalAlignment="Top" Width="35" Height="35"  HorizontalAlignment="Left" Margin="8,0,0,0">
                    <TextBox BorderThickness="0" TextChanged="RegistrationForm1_TextChanged" KeyDown="RegistrationForm1_KeyDown_1"  x:Name="RegistrationForm1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" FontSize="18" Margin="3,5,0,0"  />
                </Border>
                <Border Background="White" CornerRadius="6" BorderThickness="1" Padding="2" MinWidth="20" MinHeight="20" VerticalAlignment="Top" Width="35" Height="35"  HorizontalAlignment="Left" Margin="47,0,0,0">
                    <TextBox BorderThickness="0" TextChanged="RegistrationForm1_TextChanged" KeyDown="RegistrationForm1_KeyDown_1"  x:Name="RegistrationForm2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" FontSize="18" Margin="4,5,0,0"  />
                </Border>
                <Border Background="White" CornerRadius="6" BorderThickness="1" Padding="2" MinWidth="20" MinHeight="20" VerticalAlignment="Top" Width="35" Height="35"  HorizontalAlignment="Left" Margin="86,0,0,0">
                    <TextBox BorderThickness="0" TextChanged="RegistrationForm1_TextChanged" KeyDown="RegistrationForm1_KeyDown_1"  x:Name="RegistrationForm3" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" FontSize="18" Margin="4,5,0,0"  />
                </Border>
                <Border Background="White" CornerRadius="6" BorderThickness="1" Padding="2" MinWidth="20" MinHeight="20" VerticalAlignment="Top" Width="35" Height="35"  HorizontalAlignment="Right" Margin="0,0,85,0">
                    <TextBox BorderThickness="0" TextChanged="RegistrationForm1_TextChanged" KeyDown="RegistrationForm1_KeyDown_1"  x:Name="RegistrationForm4" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" FontSize="18" Margin="4,5,0,0"  />
                </Border>
                <Border Background="White" CornerRadius="6" BorderThickness="1" Padding="2" MinWidth="20" MinHeight="20" VerticalAlignment="Top" Width="35" Height="35"  HorizontalAlignment="Right" Margin="0,0,47,0">
                    <TextBox BorderThickness="0" TextChanged="RegistrationForm1_TextChanged" KeyDown="RegistrationForm1_KeyDown_1"  x:Name="RegistrationForm5" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" Margin="4,5,0,0" FontSize="18"  />
                </Border>
                <Border Background="White" CornerRadius="6" BorderThickness="1" Padding="2" MinWidth="20" MinHeight="20" VerticalAlignment="Top" Width="35" Height="35"  HorizontalAlignment="Right" Margin="0,0,8,0">
                    <TextBox BorderThickness="0" TextChanged="RegistrationForm1_TextChanged" KeyDown="RegistrationForm1_KeyDown_1"  x:Name="RegistrationForm6" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" FontSize="18" Margin="4,5,0,0"  />
                </Border>

            </Grid>
            <TextBlock HorizontalAlignment="Center" FontFamily="/Assets/Fonts/NunitoSans_10pt-Regular.ttf#NunitoSans" Text="Enter access code"  x:Name="StatusResponce" TextWrapping="Wrap" VerticalAlignment="Top" Grid.Row="1" FontSize="11" Margin="0,296,0,0" Foreground="#FF898989"/>
        </Grid>
        
    </Grid>

</Page>
